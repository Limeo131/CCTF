<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title if title else "CCTF" }} | Chicago Chinese Theatre Festival 芝加哥中文戏剧节</title>
  <meta name="description" content="{{ description if description else 'The inaugural Chicago Chinese Theatre Festival — May 14–31, 2026. Four groups, five productions, workshops, and industry talks.' }}">

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;600;700;800&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/CCTF/css/styles.css">

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "primary-container": "#c0e8ff",
            "surface-container-high": "#e7e8e9",
            "on-primary-fixed": "#001e2b",
            "surface": "#f8f9fa",
            "on-primary-container": "#004f69",
            "on-surface": "#191c1d",
            "on-background": "#191c1d",
            "secondary-fixed-dim": "#f4b6c9",
            "surface-container-highest": "#e1e3e4",
            "surface-container": "#edeeef",
            "on-primary": "#ffffff",
            "surface-variant": "#e1e3e4",
            "primary": "#7BC1E4",
            "secondary-container": "#fdbed1",
            "outline-variant": "#bfc8ce",
            "on-surface-variant": "#40484d",
            "on-error": "#ffffff",
            "surface-container-lowest": "#ffffff",
            "surface-container-low": "#f3f4f5",
            "inverse-surface": "#2e3132",
            "error": "#ba1a1a",
            "surface-bright": "#f8f9fa",
            "background": "#f8f9fa",
            "surface-dim": "#d9dadb",
            "outline": "#70787e"
          },
          borderRadius: {
            "DEFAULT": "0.125rem",
            "lg": "0.25rem",
            "xl": "0.5rem",
            "full": "0.75rem"
          },
          fontFamily: {
            "headline": ["Epilogue"],
            "body": ["Manrope"],
            "label": ["Manrope"]
          }
        }
      }
    }
  </script>
</head>

<body class="bg-surface text-on-surface font-body">

  <!-- Navigation -->
  <nav class="site-nav">
    <div class="site-nav__inner">
      <a href="/CCTF/" class="site-nav__logo">
        <img src="/CCTF/pictures/logo.jpg" alt="CCTF Logo">
      </a>

      <ul class="site-nav__links">
        <li><a href="/CCTF/" class="site-nav__link {% if navPage == 'home' %}active{% endif %}">Home | 首页</a></li>
        <li><a href="/CCTF/about/" class="site-nav__link {% if navPage == 'about' %}active{% endif %}">About | 关于</a></li>
        <li><a href="/CCTF/programs/" class="site-nav__link {% if navPage == 'programs' %}active{% endif %}">Programs | 节目</a></li>
        <li><a href="/CCTF/workshops/" class="site-nav__link {% if navPage == 'workshops' %}active{% endif %}">Workshops | 课程</a></li>
        <li><a href="/CCTF/venues/" class="site-nav__link {% if navPage == 'venues' %}active{% endif %}">Venues | 场馆</a></li>
      </ul>

      <button class="site-nav__hamburger" id="hamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>

      <a href="/CCTF/tickets/" class="site-nav__cta hidden md:inline-block">Tickets | 购票</a>
    </div>

    <div class="site-nav__mobile" id="mobileMenu">
      <a href="/CCTF/">Home | 首页</a>
      <a href="/CCTF/about/">About | 关于</a>
      <a href="/CCTF/programs/">Programs | 节目</a>
      <a href="/CCTF/workshops/">Workshops | 课程</a>
      <a href="/CCTF/venues/">Venues | 场馆</a>
      <a href="/CCTF/tickets/" style="color: #7BC1E4; font-weight: 700;">Tickets | 购票</a>
    </div>
  </nav>

  <!-- Page content -->
  <main>
    {{ content | safe }}
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="site-footer__inner">
      <div>
        <div class="site-footer__brand">
          <img src="/CCTF/pictures/logo.jpg" alt="CCTF Logo">
        </div>
        <p class="site-footer__tagline">© 2026 Chicago Chinese Theatre Festival.<br>All Rights Reserved.</p>
      </div>

      <div class="site-footer__nav">
        <p class="site-footer__nav-title">Navigation</p>
        <a href="/CCTF/">Home | 首页</a>
        <a href="/CCTF/about/">About | 关于</a>
        <a href="/CCTF/programs/">Programs | 节目</a>
        <a href="/CCTF/workshops/">Workshops | 课程</a>
        <a href="/CCTF/venues/">Venues | 场馆</a>
        <a href="/CCTF/tickets/">Tickets | 购票</a>
      </div>

      <div class="site-footer__social">
        <p class="site-footer__social-title">Connect | 联系我们</p>
        <a href="https://mp.weixin.qq.com/s/JaxlBBrByiYT8YLcrSC4gA" target="_blank" rel="noopener">WeChat | 微信公众号</a>
        <a href="/CCTF/pictures/IMG_5507.JPG" target="_blank" rel="noopener">Red Note | 小红书</a>
        <a href="mailto:fengchedramaclub@gmail.com">Email | 邮件</a>
      </div>
    </div>
    <div class="site-footer__bottom">
      <span class="site-footer__copyright">© 2026 Chicago Chinese Theatre Festival (CCTF). All Rights Reserved.</span>
      <span class="site-footer__copyright">风车剧社 · 周八剧社 · SAIC剧社 · 东方话剧团</span>
    </div>
  </footer>

  <script>
    // Mobile menu
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    if (hamburger && mobileMenu) {
      hamburger.addEventListener('click', () => {
        mobileMenu.classList.toggle('open');
      });
    }
  </script>

  {% block scripts %}{% endblock %}
</body>
</html>
